
# ================================
# .gitignore para Kora App
# Next.js + TypeScript + CSS Modules
# ================================

# ===== NEXT.JS =====
# Build output
.next/
out/

# Static files
/public/sitemap.xml
/public/robots.txt

# Next.js cache
.next/cache/

# Vercel deployment files
.vercel

# ===== NODE.JS =====
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Package manager lock files (mantén solo uno)
# Si usas npm, mantén package-lock.json y comenta las otras líneas
# package-lock.json
yarn.lock
pnpm-lock.yaml

# ===== VARIABLES DE ENTORNO =====
# Environment variables (IMPORTANTE: nunca subir secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ejemplo de .env.example (este SÍ se puede subir)
# .env.example

# ===== LOGS =====
# Logs de aplicación
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock

# Runtime data
pids
*.pid
*.seed

# ===== SISTEMA OPERATIVO =====
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# ===== EDITORES E IDEs =====
# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ===== TESTING =====
# Test coverage
coverage/
*.lcov
.nyc_output/

# Jest
.jest-cache/

# ===== TYPESCRIPT =====
# Compiled TypeScript files
*.tsbuildinfo
dist/
lib/

# ===== CACHE Y TEMPORALES =====
# Temporary folders
tmp/
temp/
.tmp/

# Cache directories
.cache/
.parcel-cache/

# ESLint cache
.eslintcache

# Prettier cache
.prettierCache

# Stylelint cache
.stylelintcache

# ===== DEVELOPMENT TOOLS =====
# Storybook
.storybook/public
storybook-static/

# Bundle analyzer
.bundle-analyzer/

# ===== DEPLOYMENT =====
# Build outputs que no queremos en git
build/
dist/

# ===== OTROS ARCHIVOS ESPECÍFICOS =====
# Archivos de backup
*.bak
*.backup
*.old

# Archivos de configuración local
.local
*.local

# Database files (si usas SQLite localmente)
*.sqlite
*.sqlite3
*.db

# Certificates
*.pem
*.key
*.crt

# ===== OPCIONAL: ARCHIVOS DE DESARROLLO =====
# Descomenta estas líneas si las necesitas:

# Archivos de notas y TODOs personales
# TODO.md
# NOTES.md
# scratch.txt

# Archivos de testing locales
# test-results/
# test-reports/

# Archivos de ejemplo con datos sensibles
# examples/with-auth.tsx
# examples/with-real-data.tsx

# ===== MANTENER ESTOS ARCHIVOS =====
# Archivos importantes que SÍ queremos en Git:
# README.md
# package.json
# tsconfig.json
# next.config.js
# tailwind.config.js (si lo usas)
# .env.example (plantilla de variables de entorno)
# public/ (archivos estáticos)
# src/ (código fuente)

# =====================================
# FINAL DEL ARCHIVO .gitignore
# =====================================